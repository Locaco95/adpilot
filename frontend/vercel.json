{
  "version": 2,
  "name": "adpilot",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://acceptable-surprise-production-bb7a.up.railway.app/api/:path*"
    }
  ],
  "redirects": [],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
