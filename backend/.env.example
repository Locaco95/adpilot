# ────────────────────────────────────────────────────────
# AdPilot environment configuration
# Copy to .env and fill in real values. Never commit .env.
# ────────────────────────────────────────────────────────

ENVIRONMENT=development

# Supabase (create project at supabase.com — free tier is fine)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_KEY=YOUR_SERVICE_ROLE_KEY
# Connection pooler URL (Supabase Settings → Database → Connection string → URI, "Transaction" mode)
DATABASE_URL=postgresql+asyncpg://postgres.YOUR_PROJECT_REF:YOUR_DB_PASSWORD@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

# JWT — generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=CHANGE_ME_GENERATE_WITH_python_secrets
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Claude API
CLAUDE_API_KEY=sk-ant-api03-...

# Meta (Facebook) Marketing API
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=act_

# TikTok Business API
TIKTOK_ACCESS_TOKEN=
TIKTOK_ADVERTISER_ID=

# Snapchat Marketing API
SNAPCHAT_ACCESS_TOKEN=
SNAPCHAT_AD_ACCOUNT_ID=

# Shopify Admin API
SHOPIFY_SHOP_URL=your-store.myshopify.com
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_WEBHOOK_SECRET=

# Telegram Bot — create via @BotFather, get chat ID from @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Path to thresholds config (inside container)
CONFIG_PATH=config/thresholds.yaml
